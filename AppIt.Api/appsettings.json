{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Payments": {
    "MethodAliases": {
      "PayPal": "PayPal",
      "Mastercard": "Stripe",
      "Visa": "Stripe",
      "Card": "Stripe",
      "Stripe": "Stripe",
      "CashApp": "Manual",
      "EcoCash": "Manual",
      "Bank Transfer": "Manual",
      "Manual": "Manual"
    },
    "Stripe": {
      "SecretKey": "REPLACE_WITH_STRIPE_SECRET_KEY"
    },
    "PayPal": {
      "ClientId": "REPLACE_WITH_PAYPAL_CLIENT_ID",
      "ClientSecret": "REPLACE_WITH_PAYPAL_CLIENT_SECRET",
      "Environment": "Sandbox"
    }
  },
  "Auth": {
    "JwtKey": "REPLACE_WITH_JWT_SECRET_KEY_MIN_32_CHARS",
    "JwtIssuer": "AppIt",
    "JwtAudience": "AppItClient",
    "JwtExpireMinutes": 1440
  },
  "AllowedHosts": "*"
}
